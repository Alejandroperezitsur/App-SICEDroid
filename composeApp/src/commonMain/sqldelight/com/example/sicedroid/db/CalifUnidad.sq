CREATE TABLE CalifUnidadEntity (
    matricula TEXT NOT NULL,
    materia TEXT NOT NULL,
    parciales TEXT NOT NULL DEFAULT '[]',
    last_update INTEGER NOT NULL DEFAULT 0,
    PRIMARY KEY (matricula, materia)
);

getCalifUnidad:
SELECT * FROM CalifUnidadEntity WHERE matricula = ?;

insertCalifUnidad:
INSERT OR REPLACE INTO CalifUnidadEntity(matricula, materia, parciales, last_update)
VALUES (?, ?, ?, ?);

deleteCalifUnidad:
DELETE FROM CalifUnidadEntity WHERE matricula = ?;
